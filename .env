# ===========================================
# 故障助手后端 - 环境变量配置
# ===========================================

# LLM 提供商选择: gemini / claude / qwen / local
LLM_PROVIDER=qwen

# Gemini API
#GEMINI_API_KEY=AIzaSyBWWZMfORbU5-n1WJZk0hiq8W09GHKLEsc

# Claude API (可选)
ANTHROPIC_API_KEY=

# 通义千问 API (可选)
DASHSCOPE_API_KEY=sk-392abec715b3416b84983bbe0ca0eb68

# 服务配置
HOST=0.0.0.0
PORT=8000

# 是否开启调试模式（本地开发设为 true）
DEBUG=true

# HuggingFace 镜像（国内访问 HF 用，Docling 模型首次下载需要）
HF_ENDPOINT=https://hf-mirror.com
# Docling 本地模型目录（运行 download_docling_models.py 后生效，避免 Windows 符号链接问题）
DOCLING_ARTIFACTS_PATH=./models/docling

# Qdrant Cloud（向量数据库）
# 填写你的 Qdrant Cloud 地址和 API Key
QDRANT_URL=3df841f0-ddea-469e-b4a2-506386f9f84b.us-east-1-1.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.BHRJoTvEYccVeyfoCDYy0Iypdt-55qAcuKO5XbJoA7U
QDRANT_COLLECTION_NAME=fault_assistant_rag

# Redis（对话历史，本地默认 redis://localhost:6379）
REDIS_HOST=redis-16020.c83.us-east-1-2.ec2.cloud.redislabs.com
REDIS_PORT=16020
# 对话记忆保留时间（秒）：86400 = 24小时
REDIS_PASSWORD=llzVTlVYog7FGoHmmyGjbwbrCoRb4Ekg
REDIS_TTL=86400

# ===========================================
# 对象存储 - Backblaze B2（开发阶段）
# 注册地址：https://www.backblaze.com/sign-up/cloud-storage
# ===========================================

# B2 S3 兼容端点，格式：https://s3.<region>.backblazeb2.com
# region 在 Bucket 详情页 "Endpoint" 字段中可见
B2_ENDPOINT=s3.us-east-005.backblazeb2.com

# B2 Application Key（在 Account → App Keys → Add a New Application Key 中创建）
# keyID 对应 B2_KEY_ID，applicationKey 对应 B2_APP_KEY
B2_KEY_ID=005829b7bd817bd0000000001
B2_APP_KEY=K005R8XrHu6Yp7CKnOdO40MBGoaEOAg

# Bucket 名称（在 B2 中创建的 Private Bucket 名）
B2_BUCKET_NAME=fault-assistant

# B2 region，与 endpoint 中保持一致（如 us-west-004 / eu-central-003）
B2_REGION=us-east-005
